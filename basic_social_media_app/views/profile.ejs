<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile – SocialSpark</title>
    <meta name="description" content="View and manage your SocialSpark profile and posts.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0d0d14; }
        .glass { background: rgba(255,255,255,0.04); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.08); }
        .post-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            transition: all 0.3s ease;
        }
        .post-card:hover {
            background: rgba(255,255,255,0.06);
            border-color: rgba(139,92,246,0.3);
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(139,92,246,0.1);
        }
        .nav-glass {
            background: rgba(13,13,20,0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .btn-primary {
            background: linear-gradient(135deg, #8b5cf6, #6d28d9);
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #a78bfa, #7c3aed);
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(139,92,246,0.35);
        }
        .btn-ghost {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.3s ease;
        }
        .btn-ghost:hover { background: rgba(255,255,255,0.09); }
        .like-btn {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2);
            color: #f87171;
            transition: all 0.3s ease;
        }
        .like-btn:hover { background: rgba(239,68,68,0.2); transform: scale(1.05); }
        .delete-btn {
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.15);
            color: #fc8181;
            transition: all 0.3s ease;
        }
        .delete-btn:hover { background: rgba(239,68,68,0.18); }
        .edit-btn {
            background: rgba(59,130,246,0.1);
            border: 1px solid rgba(59,130,246,0.2);
            color: #93c5fd;
            transition: all 0.3s ease;
        }
        .edit-btn:hover { background: rgba(59,130,246,0.2); }
        .avatar-gradient { background: linear-gradient(135deg, #8b5cf6, #ec4899); }
        .textarea-field {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #e2e8f0;
            resize: none;
            transition: all 0.3s ease;
        }
        .textarea-field:focus {
            outline: none;
            border-color: #8b5cf6;
            background: rgba(139,92,246,0.06);
            box-shadow: 0 0 0 3px rgba(139,92,246,0.12);
        }
        .textarea-field::placeholder { color: #4a5568; }
        .stat-card {
            background: rgba(139,92,246,0.08);
            border: 1px solid rgba(139,92,246,0.15);
        }
        .orb { position: fixed; border-radius: 50%; filter: blur(100px); opacity: 0.07; pointer-events: none; z-index: 0; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        .fade-up { animation: fadeUp 0.5s ease-out both; }
        .fade-up-delay-1 { animation: fadeUp 0.5s ease-out 0.15s both; }
        .fade-up-delay-2 { animation: fadeUp 0.5s ease-out 0.3s both; }
    </style>
</head>
<body class="min-h-screen text-white">

    <div class="orb w-[600px] h-[600px] bg-purple-600 top-0 right-0"></div>
    <div class="orb w-[400px] h-[400px] bg-indigo-500 bottom-0 left-0"></div>

    <!-- Navbar -->
    <nav class="nav-glass sticky top-0 z-50">
        <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3 no-underline">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9)">
                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
                    </svg>
                </div>
                <span class="text-lg font-bold text-white">SocialSpark</span>
            </a>
            <div class="flex gap-3">
                <a href="/" class="btn-ghost text-sm text-white font-medium px-4 py-2 rounded-xl inline-block no-underline">← Feed</a>
                <a href="/logout" class="text-slate-400 hover:text-red-400 text-sm font-medium transition-colors px-3 py-2 inline-block no-underline">Logout</a>
            </div>
        </div>
    </nav>

    <main class="relative z-10 max-w-2xl mx-auto px-6 py-10 space-y-8">

        <!-- Profile Card -->
        <div class="glass rounded-3xl p-8 fade-up">
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
                <!-- Avatar -->
                <div class="relative flex-shrink-0">
                    <div class="avatar-gradient p-1 rounded-full">
                        <img
                            src="<%= user.profilepic %>"
                            alt="Profile Picture"
                            class="w-24 h-24 rounded-full object-cover block"
                            style="border: 3px solid #0d0d14"
                        >
                    </div>
                    <a href="/test"
                        class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full flex items-center justify-center no-underline shadow-lg"
                        style="background:linear-gradient(135deg,#8b5cf6,#6d28d9)"
                        title="Change photo">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </a>
                </div>

                <!-- Info -->
                <div class="flex-1 text-center sm:text-left">
                    <h1 class="text-2xl font-bold text-white"><%= user.name %></h1>
                    <p class="text-slate-400 text-sm mt-1"><%= user.email %></p>
                    <div class="flex flex-wrap justify-center sm:justify-start gap-3 mt-4">
                        <div class="stat-card px-4 py-2 rounded-xl text-center">
                            <p class="text-lg font-bold text-purple-400"><%= user.post.length %></p>
                            <p class="text-xs text-slate-500">Posts</p>
                        </div>
                        <div class="stat-card px-4 py-2 rounded-xl text-center">
                            <p class="text-lg font-bold text-purple-400"><%= user.age %></p>
                            <p class="text-xs text-slate-500">Age</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Create Post -->
        <div class="glass rounded-3xl p-6 fade-up-delay-1">
            <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-widest mb-4">What's on your mind?</h2>
            <form action="/createpost" method="POST">
                <textarea
                    name="content"
                    rows="4"
                    placeholder="Share something with the world..."
                    class="textarea-field w-full rounded-2xl px-4 py-3 text-sm"
                ></textarea>
                <div class="flex justify-end mt-3">
                    <button type="submit" class="btn-primary px-6 py-2.5 rounded-xl text-sm font-semibold text-white">
                        Publish Post ✦
                    </button>
                </div>
            </form>
        </div>

        <!-- My Posts -->
        <div class="fade-up-delay-2">
            <% if(user.post.length) { %>
                <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4">Your Posts (<%= user.post.length %>)</h2>
                <div class="space-y-4">
                    <% user.post.forEach(function(post){ %>
                        <article class="post-card rounded-2xl p-6">
                            <!-- Author row -->
                            <div class="flex items-center gap-3 mb-3">
                                <div class="avatar-gradient p-0.5 rounded-full">
                                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-white font-bold text-xs" style="background:#1a1a2e">
                                        <%= user.name[0].toUpperCase() %>
                                    </div>
                                </div>
                                <p class="text-white font-semibold text-sm"><%= user.name %></p>
                            </div>

                            <!-- Content -->
                            <p class="text-slate-300 leading-relaxed text-sm mb-5"><%= post.content %></p>

                            <!-- Actions -->
                            <div class="flex items-center gap-3 flex-wrap">
                                <a href="/like/<%= post._id %>" class="like-btn px-4 py-2 rounded-xl text-xs font-semibold flex items-center gap-2 no-underline">
                                    ❤️ Like &nbsp;<span class="bg-red-500/20 px-2 py-0.5 rounded-full text-red-300"><%= post.likes.length %></span>
                                </a>
                                <a href="/editpost/<%= post._id %>" class="edit-btn px-4 py-2 rounded-xl text-xs font-semibold no-underline">
                                    ✏️ Edit
                                </a>
                                <form method="POST" action="/deletepost/<%= post._id %>" class="inline">
                                    <button type="submit" class="delete-btn px-4 py-2 rounded-xl text-xs font-semibold">
                                        🗑 Delete
                                    </button>
                                </form>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-16">
                    <div class="text-5xl mb-4">✍️</div>
                    <p class="text-slate-400 font-medium">No posts yet</p>
                    <p class="text-slate-600 text-sm mt-1">Share your first thought above!</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>